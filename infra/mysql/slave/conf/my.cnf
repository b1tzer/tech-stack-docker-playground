[mysqld]
# Basic Configuration
server-id = 2
log_bin = mysql-bin
binlog_format = row
gtid_mode = ON
enforce_gtid_consistency = ON

# Replication Settings
relay_log = mysql-relay-bin

# Performance Settings
innodb_buffer_pool_size = 256M
innodb_log_file_size = 100M
max_connections = 200

# Security Settings
skip_name_resolve = 1
bind-address = 0.0.0.0