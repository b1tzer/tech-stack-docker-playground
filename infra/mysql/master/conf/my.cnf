[mysqld]
# Basic Configuration
server-id = 1
log_bin = mysql-bin
binlog_format = row
gtid_mode = ON
enforce_gtid_consistency = ON

# Replication Settings
binlog_do_db = business_db
replicate_do_db = business_db

# Performance Settings
innodb_buffer_pool_size = 256M
innodb_log_file_size = 100M
max_connections = 200

# Security Settings
skip_name_resolve = 1
bind-address = 0.0.0.0